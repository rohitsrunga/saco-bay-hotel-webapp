---
import Layout from '../layouts/Layout.astro';

const rooms = [
	{
		eyebrow: 'More Space',
		title: 'Deluxe King',
		image: `${import.meta.env.BASE_URL}assets/rooms/king.webp`,
		alt: 'Deluxe King room at Saco Bay Hotel Saco Maine',
		specs: ['2 Guests', '1 King Bed'],
		description:
			'Our largest room, with a king bed, a desk, and enough room to spread out a bit. A good choice if you are staying more than a night or just do not like a cramped room.',
		highlights: ['Dedicated desk', 'Mini fridge & microwave', 'Keurig coffee maker', 'Fast WiFi']
	},
	{
		eyebrow: 'Straightforward Stay',
		title: 'Deluxe Double Queen',
		image: `${import.meta.env.BASE_URL}assets/rooms/queen.webp`,
		alt: 'Deluxe Double Queen room at Saco Bay Hotel Saco Maine',
		specs: ['2–4 Guests', '2 Queen Beds'],
		description:
			'A double queen room that keeps things simple. It has the same basic amenities as the larger rooms, just in a layout that works well for a quick stay or a small group.',
		highlights: ['Two queen beds', 'Simple, efficient layout', 'Fast WiFi', 'Keurig, fridge & microwave']
	},
	{
		eyebrow: 'Most Room',
		title: 'Suite King',
		image: `${import.meta.env.BASE_URL}assets/rooms/suite.webp`,
		alt: 'Suite King room at Saco Bay Hotel Maine',
		specs: ['2–4 Guests', '1 King Bed', 'Suite'],
		description:
			'The Suite King gives you the most room to work with. If you want a little breathing room after a long beach day or a long drive up the coast, this is the one.',
		highlights: ['King bed', 'Full suite layout', 'Fast WiFi', 'Mini fridge & microwave']
	}
];
---

<Layout title="Rooms & Suites | Saco Bay Hotel — Saco, Maine" description="Choose from Deluxe King, Double Queen, or Suite King rooms at Saco Bay Hotel. Modern comfort near Old Orchard Beach and the Maine coast.">
	<script type="application/ld+json" set:html={JSON.stringify([
		{
			"@context": "https://schema.org",
			"@type": "HotelRoom",
			"name": "Deluxe King",
			"description": "Spacious king room with a dedicated desk, mini fridge, microwave, and Keurig at Saco Bay Hotel in Saco, Maine — minutes from Old Orchard Beach.",
			"occupancy": { "@type": "QuantitativeValue", "maxValue": 2 },
			"bed": { "@type": "BedDetails", "typeOfBed": "King", "numberOfBeds": 1 },
			"amenityFeature": [
				{ "@type": "LocationFeatureSpecification", "name": "Free WiFi", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Mini Fridge", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Microwave", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Keurig Coffee Maker", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Dedicated Desk", "value": true }
			],
			"image": "https://sacobayhotel.com/assets/rooms/king.webp"
		},
		{
			"@context": "https://schema.org",
			"@type": "HotelRoom",
			"name": "Deluxe Double Queen",
			"description": "Double queen room with two beds — great for families or groups visiting Old Orchard Beach, Maine.",
			"occupancy": { "@type": "QuantitativeValue", "maxValue": 4 },
			"bed": { "@type": "BedDetails", "typeOfBed": "Queen", "numberOfBeds": 2 },
			"amenityFeature": [
				{ "@type": "LocationFeatureSpecification", "name": "Free WiFi", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Mini Fridge", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Microwave", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Keurig Coffee Maker", "value": true }
			],
			"image": "https://sacobayhotel.com/assets/rooms/queen.webp"
		},
		{
			"@context": "https://schema.org",
			"@type": "HotelRoom",
			"name": "Suite King",
			"description": "Full suite with a king bed and separate living area at Saco Bay Hotel in Saco, Maine.",
			"occupancy": { "@type": "QuantitativeValue", "maxValue": 4 },
			"bed": { "@type": "BedDetails", "typeOfBed": "King", "numberOfBeds": 1 },
			"amenityFeature": [
				{ "@type": "LocationFeatureSpecification", "name": "Free WiFi", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Separate Living Area", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Mini Fridge", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Microwave", "value": true },
				{ "@type": "LocationFeatureSpecification", "name": "Keurig Coffee Maker", "value": true }
			],
			"image": "https://sacobayhotel.com/assets/rooms/suite.webp"
		}
	])} />
	<section class="rooms-hero bg-warm">
		<div class="container rooms-hero-inner">
			<span class="eyebrow">Saco Bay Hotel</span>
			<h1>Our Rooms</h1>
			<p>Three room types, all set up for an easy stay near the beach, downtown Saco, and the rest of the southern Maine coast. Saco Bay Hotel is minutes from Old Orchard Beach, Funtown Splashtown USA, and the southern Maine coast — a practical home base whether you are here for the beach or just passing through.</p>
		</div>
	</section>

	<section class="rooms-overview bg-coastal textured">
		<div class="container">
			<div class="section-heading">
				<span class="eyebrow">Choose Your Stay</span>
				<h2 class="navy-text">Pick What Fits</h2>
				<p>Every room comes with the same basics: WiFi, Keurig, fridge, microwave, and a clean place to land at the end of the day. The main question is how much space you want.</p>
			</div>

			<div class="rooms-editorial-stack">
				{
					rooms.map((room, index) => (
						<article class={`room-feature${index % 2 === 1 ? ' reverse' : ''}`}>
							<div class="room-feature-image">
								<img src={room.image} alt={room.alt} loading="lazy" decoding="async" width="4240" height="2832" />
							</div>
							<div class="room-feature-content">
								<span class="sans-caps">{room.eyebrow}</span>
								<h3>{room.title}</h3>
								<div class="room-feature-specs">
									{room.specs.map((spec) => <span>{spec}</span>)}
								</div>
								<p>{room.description}</p>
								<ul class="room-feature-list">
									{room.highlights.map((item) => <li>{item}</li>)}
								</ul>
								<a href="/book" class="btn-primary">Book This Room</a>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>
</Layout>

<style>
	.rooms-hero {
		padding: 11rem 0 5rem;
	}

	.rooms-hero-inner {
		max-width: 860px;
	}

	.rooms-hero h1 {
		font-size: clamp(3.8rem, 9vw, 6.5rem);
		line-height: 0.95;
		color: var(--navy-deep);
		margin-bottom: 1.5rem;
	}

	.rooms-hero p {
		max-width: 660px;
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--text-muted);
	}

	.rooms-overview {
		padding: 0 0 3rem;
	}

	.rooms-overview > .container {
		padding-top: 5.5rem;
	}

	.section-heading {
		max-width: 760px;
		margin-bottom: 4rem;
		position: relative;
		z-index: 2;
	}

	.section-heading h2 {
		font-size: 3.5rem;
		margin-bottom: 1rem;
	}

	.section-heading p {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--text-muted);
	}

	.rooms-editorial-stack {
		display: grid;
		gap: 2.5rem;
		position: relative;
		z-index: 2;
	}

	.room-feature {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		align-items: stretch;
		background: rgba(255, 255, 255, 0.74);
		border: 1px solid rgba(30, 45, 75, 0.08);
		box-shadow: 0 20px 45px rgba(30, 45, 75, 0.08);
		backdrop-filter: blur(10px);
		overflow: hidden;
	}

	.room-feature.reverse {
		grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.05fr);
	}

	.room-feature.reverse .room-feature-image {
		order: 2;
	}

	.room-feature-image img {
		display: block;
		width: 100%;
		height: 100%;
		min-height: 420px;
		object-fit: cover;
	}

	.room-feature-content {
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.room-feature-content .sans-caps {
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.room-feature-content h3 {
		font-size: 3rem;
		line-height: 1;
		color: var(--navy-deep);
		margin-bottom: 1.25rem;
	}

	.room-feature-specs {
		display: flex;
		flex-wrap: wrap;
		gap: 1.1rem;
		font-family: var(--font-sans);
		font-size: 0.67rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}

	.room-feature-content p {
		font-size: 1rem;
		line-height: 1.8;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
		max-width: 34rem;
	}

	.room-feature-list {
		list-style: none;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75rem 1rem;
		margin-bottom: 2rem;
	}

	.room-feature-list li {
		padding-left: 1.1rem;
		position: relative;
		font-weight: 600;
		color: var(--navy-deep);
	}

	.room-feature-list li::before {
		content: "—";
		position: absolute;
		left: 0;
		color: var(--accent);
	}

	@media (max-width: 960px) {
		.room-feature,
		.room-feature.reverse {
			grid-template-columns: 1fr;
		}

		.room-feature.reverse .room-feature-image {
			order: 0;
		}

		.section-heading h2 {
			font-size: 2.8rem;
		}
	}

	@media (max-width: 768px) {
		.rooms-hero {
			padding: 9rem 0 4rem;
		}

		.rooms-hero h1 {
			font-size: 3.4rem;
		}

		.rooms-hero p,
		.section-heading p,
		.room-feature-content p {
			font-size: 1rem;
		}

		.room-feature-image img {
			min-height: 280px;
		}

		.room-feature-content {
			padding: 1.5rem;
		}

		.room-feature-content h3 {
			font-size: 2.25rem;
		}

		.room-feature-list {
			grid-template-columns: 1fr;
		}
	}
</style>
