---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import exteriorPropertyImg from '../../assets/gallery/exterior_property.jpg';
import foodImg from '../../assets/amenities/food.jpg';
import kingBedImg from '../../assets/gallery/king_bed.jpg';
import lobbyImg from '../../assets/amenities/lobby.jpg';

const posts = [
	{
		slug: 'old-orchard-beach-summer-2026',
		title: "Old Orchard Beach Summer 2026: Events, Festivals & What's New",
		date: 'April 2026',
		category: 'Seasonal Guide',
		excerpt: "Your full guide to summer 2026 at Old Orchard Beach. Weekly fireworks, the Rock the Park concert series, Palace Playland's new coaster, and what to expect when you get here.",
	},
	{
		slug: 'july-4th-old-orchard-beach',
		title: "July 4th at Old Orchard Beach: What to Expect",
		date: 'April 2026',
		category: 'Seasonal Guide',
		excerpt: "Fireworks over the Atlantic, a packed boardwalk, and the best lobster roll you will have all summer. Here is how to do July 4th at Old Orchard Beach.",
	},
	{
		slug: 'things-to-do-old-orchard-beach',
		title: "The Ultimate Guide to Old Orchard Beach, Maine",
		date: 'April 2026',
		category: 'Destination Guide',
		excerpt: "Seven miles of beach, a 500-foot wooden pier, and the last traditional beachfront amusement park in New England. Everything to know before your first or tenth visit.",
	},
	{
		slug: 'palace-playland-guide',
		title: "Palace Playland: Everything You Need to Know",
		date: 'April 2026',
		category: 'Attraction Guide',
		excerpt: "The only traditional oceanfront amusement park left on the New England coast. What to ride, what to skip, and how to make the most of a visit.",
	},
	{
		slug: 'funtown-splashtown-guide',
		title: "Funtown Splashtown USA: Tips, Best Rides & How to Plan Your Day",
		date: 'April 2026',
		category: 'Attraction Guide',
		excerpt: "Maine's largest amusement and water park is less than 2 miles from the hotel. A full guide to Excalibur, the water slides, and how to plan a full day.",
	},
	{
		slug: 'ferry-beach-state-park',
		title: "Ferry Beach State Park: Maine's Quiet Beach Near Saco",
		date: 'April 2026',
		category: 'Nature Guide',
		excerpt: "Two miles from the hotel, Ferry Beach is one of the most underrated state parks in Maine. Wide sand, rare tupelo trees, and a lot fewer people than Old Orchard.",
	},
	{
		slug: 'boston-to-old-orchard-beach',
		title: "Boston to Old Orchard Beach by Car: The Complete Guide",
		date: 'April 2026',
		category: 'Travel Guide',
		excerpt: "About 95 miles up I-95. What to know about traffic, tolls, road trip stops, and why Saco makes a better base than staying right in Old Orchard Beach.",
	},
	{
		slug: 'things-to-do-saco-maine-outdoors',
		title: "Outdoor Things to Do Near Saco, Maine",
		date: 'April 2026',
		category: 'Activity Guide',
		excerpt: "Beyond the boardwalk: salt marshes, river paddles, birding spots, and coastal trails within 15 miles of the hotel.",
	},
];
---

<Layout
	title="Local Guide & Blog | Saco Bay Hotel"
	description="Tips, guides, and local knowledge for visitors to Old Orchard Beach and southern Maine, from the team at Saco Bay Hotel in Saco, ME."
>
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sacobayhotel.com/" },
			{ "@type": "ListItem", "position": 2, "name": "Local Guide", "item": "https://sacobayhotel.com/blog" }
		]
	})} />

	<section class="blog-hero bg-warm">
		<div class="container blog-hero-inner">
			<span class="eyebrow">Saco Bay Hotel</span>
			<h1>Local Guide</h1>
			<p>We have been in Saco for a long time. This is the stuff we tell every guest who asks what to do, where to go, and what is worth the drive.</p>
		</div>
	</section>

	<section class="blog-photo-strip">
		<div class="blog-strip-grid">
			<figure class="strip-photo strip-photo-tall">
				<Image
					src={exteriorPropertyImg}
					alt="Saco Bay Hotel exterior"
					loading="eager"
					width={800}
					height={600}
				/>
			</figure>
			<div class="strip-photo-stack">
				<figure class="strip-photo">
					<Image
						src={foodImg}
						alt="Hot breakfast included at Saco Bay Hotel"
						loading="eager"
						width={800}
						height={534}
					/>
				</figure>
				<figure class="strip-photo">
					<Image
						src={kingBedImg}
						alt="King room at Saco Bay Hotel"
						loading="lazy"
						width={800}
						height={534}
					/>
				</figure>
			</div>
			<figure class="strip-photo strip-photo-tall">
				<Image
					src={lobbyImg}
					alt="Lobby at Saco Bay Hotel"
					loading="lazy"
					width={800}
					height={600}
				/>
			</figure>
		</div>
	</section>

	<section class="blog-list bg-mist textured">
		<div class="container">
			<div class="posts-grid">
				{posts.map((post) => (
					<article class="post-card">
						<div class="post-meta">
							<span class="post-category">{post.category}</span>
							<span class="post-date">{post.date}</span>
						</div>
						<h2 class="post-title">
							<a href={`/blog/${post.slug}`}>{post.title}</a>
						</h2>
						<p class="post-excerpt">{post.excerpt}</p>
						<a href={`/blog/${post.slug}`} class="post-read-more">Read More &rarr;</a>
					</article>
				))}
			</div>
		</div>
	</section>
</Layout>

<style>
	.blog-hero {
		padding: 11rem 0 5rem;
	}

	.blog-hero-inner {
		max-width: 760px;
	}

	.blog-hero h1 {
		font-size: clamp(3.8rem, 9vw, 6.5rem);
		line-height: 0.95;
		color: var(--navy-deep);
		margin-bottom: 1.5rem;
	}

	.blog-hero p {
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--text-muted);
		max-width: 560px;
	}

	/* Photo strip */
	.blog-photo-strip {
		width: 100%;
		overflow: hidden;
	}

	.blog-strip-grid {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		height: 360px;
		gap: 3px;
	}

	.strip-photo-stack {
		display: grid;
		grid-template-rows: 1fr 1fr;
		gap: 3px;
	}

	.strip-photo {
		margin: 0;
		overflow: hidden;
		line-height: 0;
	}

	.strip-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.5s ease;
	}

	.strip-photo:hover img {
		transform: scale(1.03);
	}

	.strip-photo-tall img {
		height: 360px;
	}

	/* Post list */
	.blog-list {
		padding: 5rem 0 7rem;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
		gap: 1.5rem;
	}

	.post-card {
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(30, 45, 75, 0.08);
		box-shadow: 0 12px 32px rgba(30, 45, 75, 0.07);
		backdrop-filter: blur(10px);
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.post-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 20px 45px rgba(30, 45, 75, 0.12);
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.post-category {
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--accent);
	}

	.post-date {
		font-size: 0.7rem;
		color: var(--text-muted);
	}

	.post-title {
		font-size: 1.45rem;
		line-height: 1.25;
		color: var(--navy-deep);
	}

	.post-title a {
		color: inherit;
		transition: color 0.3s ease;
	}

	.post-title a:hover {
		color: #2E6DA4;
	}

	.post-excerpt {
		font-size: 0.92rem;
		line-height: 1.75;
		color: var(--text-muted);
		flex-grow: 1;
	}

	.post-read-more {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		font-weight: 700;
		color: var(--accent);
		margin-top: 0.5rem;
		transition: opacity 0.3s ease;
	}

	.post-read-more:hover {
		opacity: 0.7;
	}

	@media (max-width: 1024px) {
		.blog-hero {
			padding: 9rem 0 4rem;
		}

		.blog-hero h1 {
			font-size: 3.4rem;
		}

		.blog-strip-grid {
			height: 260px;
		}

		.strip-photo-tall img {
			height: 260px;
		}
	}

	@media (max-width: 768px) {
		.blog-strip-grid {
			grid-template-columns: 1fr 1fr;
			height: 220px;
		}

		.blog-strip-grid .strip-photo-tall:last-child {
			display: none;
		}

		.strip-photo-tall img {
			height: 220px;
		}

		.posts-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.blog-strip-grid {
			grid-template-columns: 1fr;
			height: auto;
		}

		.strip-photo-stack {
			grid-template-rows: auto;
			grid-template-columns: 1fr 1fr;
		}

		.strip-photo-tall img {
			height: 200px;
		}

		.strip-photo img {
			height: 140px;
		}
	}
</style>
