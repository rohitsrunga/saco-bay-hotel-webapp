---
import Layout from '../layouts/Layout.astro';

const testimonials = [
	{
		quote: 'We wanted to be close to OOB without all the noise. Was an easy drive to the beach in the morning, quiet at night, and plenty of space in the room to shower off the sand, and relax.',
		author: 'Karen D.',
		source: 'Google Review'
	},
	{
		quote: 'Stayed here for a long weekend and used it as our base for Saco, Biddeford, and Old Orchard. Loved chatting with the staff, and room was clean, spacious, and comfortable.',
		author: 'Juan L.',
		source: 'TripAdvisor'
	},
	{
		quote: 'This felt like a much easier way to do southern Maine. We grabbed breakfast, spent the day down by the water, got dinner in Biddeford, and lounged in our room. Straightforward stay, friendly staff, and a good spot if you know the area.',
		author: 'Jen L.',
		source: 'Choice Privileges'
	}
];

const roomSlides = [
	{
		id: 'king',
		eyebrow: 'Room To Spread Out',
		title: 'Deluxe King',
		image: `${import.meta.env.BASE_URL}assets/rooms/king.jpg`,
		alt: 'Deluxe King room at Saco Bay Hotel Saco Maine',
		specs: ['2 Guests', '1 King Bed', '350 SQFT'],
		summary: 'Our biggest room, with enough space to spread out a little.',
		description:
			'This is the one to book if you do not want to feel boxed in. You get a king bed, a proper desk, blackout shades, a Keurig, and enough room to toss your bag down and stay awhile.'
	},
	{
		id: 'queen',
		eyebrow: 'Easy And Simple',
		title: 'Deluxe Queen',
		image: `${import.meta.env.BASE_URL}assets/rooms/queen.jpg`,
		alt: 'Deluxe Queen room at Saco Bay Hotel Saco Maine',
		specs: ['2 Guests', '1 Queen Bed', '280 SQFT'],
		summary: 'A straightforward room that works well for a quick coast trip.',
		description:
			'Good for one night or a few. It has the same basics as the king rooms, just in a tighter layout that keeps things easy.'
	},
	{
		id: 'double',
		eyebrow: 'More Elbow Room',
		title: 'Suite King',
		image: `${import.meta.env.BASE_URL}assets/rooms/suite.jpg`,
		alt: 'Suite King room at Saco Bay Hotel Maine',
		specs: ['2 Guests', '1 King Bed', 'Suite'],
		summary: 'A full suite when you want more space than a standard room gives you.',
		description:
			'If you are planning to be out all day and want a room that still feels good to come back to, this is the one. It gives you a king bed and extra living space without getting fussy about it.'
	}
];

const roomsHref = `${import.meta.env.BASE_URL}rooms`;
const experienceHref = `${import.meta.env.BASE_URL}experience`;
---

<Layout title="Saco Bay Hotel | Saco, ME | Stay Near Old Orchard Beach" description="Saco Bay Hotel in Saco, Maine, near Old Orchard Beach, Camp Ellis, and the rest of the southern Maine coast.">
	<section id="home" class="hero-press">
		<div id="hero-placeholder" class="hero-image-overlay" style={`background: url('${import.meta.env.BASE_URL}main-hero-bg.png') center/cover no-repeat;`}></div>

		<video id="hero-video" class="hero-video" autoplay muted loop playsinline>
			<source src={`${import.meta.env.BASE_URL}saco_bay_intro.mp4`} type="video/mp4" />
		</video>

		<div class="hero-overlay-press"></div>

		<div class="hero-container">
			<div class="hero-top-row">
				<div class="hero-content-press">
					<div class="hero-logo-wrapper fade-in-up">
						<img
							class="main-logo"
							src={`${import.meta.env.BASE_URL}assets/SB.svg`}
							alt="Saco Bay Hotel logo"
						/>
					</div>
					<div class="hero-slogan-box fade-in-up">
						<div class="hero-logo-wrapper hero-logo-mobile">
							<img
								class="main-logo"
								src={`${import.meta.env.BASE_URL}assets/SB.svg`}
								alt="Saco Bay Hotel logo"
							/>
						</div>
						<div class="slogan-divider-line"></div>
						<h1 class="hero-h1">Stay in Saco.<br>Head to the beach.</h1>
					</div>
				</div>

				<div class="booking-widget-container fade-in">
					<div class="booking-card">
						<div class="date-row">
							<div class="date-box" id="checkin-trigger">
								<span class="label">Check In</span>
								<input type="date" id="checkin-date" class="hidden-input" />
								<span class="day" id="checkin-day">--</span>
								<span class="month" id="checkin-month">Select</span>
							</div>
							<div class="date-box" id="checkout-trigger">
								<span class="label">Check Out</span>
								<input type="date" id="checkout-date" class="hidden-input" />
								<span class="day" id="checkout-day">--</span>
								<span class="month" id="checkout-month">Select</span>
							</div>
						</div>

						<div class="booking-details-row">
							<div class="rooms-section">
								<div class="custom-input-box">
									<select id="rooms-count" class="select-reset">
										<option value="1" selected>1 ROOM</option>
										<option value="2">2 ROOMS</option>
										<option value="3">3 ROOMS</option>
										<option value="4">4 ROOMS</option>
										<option value="5">5 ROOMS</option>
									</select>
								</div>
							</div>
							<div class="occupancy-section">
								<div class="custom-input-box">
									<select id="adults-count" class="select-reset">
										<option value="1" selected>1 ADULT</option>
										<option value="2">2 ADULTS</option>
										<option value="3">3 ADULTS</option>
										<option value="4">4 ADULTS</option>
										<option value="5">5 ADULTS</option>
										<option value="6">6 ADULTS</option>
										<option value="7">7 ADULTS</option>
										<option value="8">8 ADULTS</option>
										<option value="9">9 ADULTS</option>
										<option value="10">10 ADULTS</option>
									</select>
								</div>
							</div>
						</div>

						<button id="main-book-btn" class="btn-primary booking-submit">
							BOOK YOUR STAY
						</button>
					</div>
				</div>
			</div>

				<div class="testimonials-carousel" aria-label="Guest testimonials">
					<div class="testimonials-header">
						<span class="eyebrow hero-eyebrow">What our guests say</span>
					</div>
					<div class="testimonial-carousel-shell">
						<button class="testimonial-nav prev" type="button" aria-label="Previous testimonial">‹</button>
						<div class="testimonial-viewport">
							<div class="testimonials-track">
								{
									testimonials.map((testimonial) => (
										<article class="testimonial-card">
											<div class="testimonial-stars" aria-label="Five stars">★★★★★</div>
											<p>&ldquo;{testimonial.quote}&rdquo;</p>
											<span class="testimonial-author">{testimonial.author}, {testimonial.source}</span>
										</article>
									))
								}
							</div>
						</div>
						<button class="testimonial-nav next" type="button" aria-label="Next testimonial">›</button>
					</div>
					<div class="testimonial-dots" aria-label="Testimonial pagination">
						{
							testimonials.map((_, index) => (
								<button
									type="button"
									class={`testimonial-dot${index === 0 ? ' is-active' : ''}`}
									data-index={index}
									aria-label={`Go to testimonial ${index + 1}`}
								></button>
							))
						}
					</div>
				</div>
			</div>
		</section>

	<script>
		const video = document.getElementById('hero-video') as HTMLVideoElement | null;
		const placeholder = document.getElementById('hero-placeholder') as HTMLElement | null;

		if (video && placeholder) {
			video.onplaying = () => {
				placeholder.style.opacity = '0';
				setTimeout(() => {
					placeholder.style.display = 'none';
				}, 1500);
			};
		}

		const checkinInput = document.getElementById('checkin-date') as HTMLInputElement | null;
		const checkoutInput = document.getElementById('checkout-date') as HTMLInputElement | null;
		const adultsSelect = document.getElementById('adults-count') as HTMLSelectElement | null;
		const roomsSelect = document.getElementById('rooms-count') as HTMLSelectElement | null;
		const mainBookBtn = document.getElementById('main-book-btn');

		const getLocalDateStr = (date: Date) => {
			const offset = date.getTimezoneOffset();
			const localDate = new Date(date.getTime() - offset * 60 * 1000);
			return localDate.toISOString().split('T')[0];
		};

		const today = new Date();
		const tomorrow = new Date();
		tomorrow.setDate(tomorrow.getDate() + 1);

		if (checkinInput && checkoutInput) {
			checkinInput.value = getLocalDateStr(today);
			checkoutInput.value = getLocalDateStr(tomorrow);
			updateDateDisplay();
		}

		function updateDateDisplay() {
			const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

			if (checkinInput?.value) {
				const d = new Date(`${checkinInput.value}T00:00:00`);
				const checkinDay = document.getElementById('checkin-day');
				const checkinMonth = document.getElementById('checkin-month');

				if (checkinDay) checkinDay.textContent = d.getDate().toString();
				if (checkinMonth) checkinMonth.textContent = months[d.getMonth()];
			}

			if (checkoutInput?.value) {
				const d = new Date(`${checkoutInput.value}T00:00:00`);
				const checkoutDay = document.getElementById('checkout-day');
				const checkoutMonth = document.getElementById('checkout-month');

				if (checkoutDay) checkoutDay.textContent = d.getDate().toString();
				if (checkoutMonth) checkoutMonth.textContent = months[d.getMonth()];
			}
		}

		[checkinInput, checkoutInput].forEach((el) => el?.addEventListener('change', updateDateDisplay));

		function getBookingUrl() {
			const checkin = checkinInput?.value ?? '';
			const checkout = checkoutInput?.value ?? '';
			const adults = adultsSelect?.value ?? '2';

			return `https://us2.cloudbeds.com/en/reservation/wOOQW0?currency=usd&checkin=${checkin}&checkout=${checkout}&adults=${adults}&kids=0`;
		}

		mainBookBtn?.addEventListener('click', () => {
			window.open(getBookingUrl(), '_blank');
		});

		document.querySelectorAll('.btn-primary:not(#main-book-btn)').forEach((btn) => {
			btn.addEventListener('click', (e) => {
				if (!(btn instanceof HTMLAnchorElement) && !(btn instanceof HTMLButtonElement)) return;
				e.preventDefault();
				window.open(getBookingUrl(), '_blank');
			});
		});

		const testimonialTrack = document.querySelector('.testimonials-track') as HTMLElement | null;
		const testimonialViewport = document.querySelector('.testimonial-viewport') as HTMLElement | null;
		const testimonialCards = Array.from(document.querySelectorAll('.testimonial-card')) as HTMLElement[];
		const testimonialDots = Array.from(document.querySelectorAll('.testimonial-dot')) as HTMLButtonElement[];
		const prevButton = document.querySelector('.testimonial-nav.prev') as HTMLButtonElement | null;
		const nextButton = document.querySelector('.testimonial-nav.next') as HTMLButtonElement | null;
		let activeSlide = 0;
		let autoplayId: number | undefined;

		function isMobileCarousel() {
			return window.innerWidth <= 768;
		}

		function renderTestimonials(index: number) {
			if (!testimonialTrack || !testimonialViewport || testimonialCards.length === 0) return;

			activeSlide = (index + testimonialCards.length) % testimonialCards.length;

			if (isMobileCarousel()) {
				testimonialTrack.style.transform = 'none';
				testimonialCards.forEach((card, cardIndex) => {
					card.classList.remove('is-active', 'is-before', 'is-after');
					if (cardIndex === activeSlide) {
						card.classList.add('is-active');
					} else if (cardIndex === (activeSlide - 1 + testimonialCards.length) % testimonialCards.length) {
						card.classList.add('is-before');
					} else {
						card.classList.add('is-after');
					}
				});
			} else {
				testimonialTrack.style.transform = 'translateX(0)';
				testimonialCards.forEach((card) => {
					card.classList.remove('is-active', 'is-before', 'is-after');
				});
			}

			testimonialDots.forEach((dot, dotIndex) => {
				dot.classList.toggle('is-active', dotIndex === activeSlide);
			});
		}

		function startAutoplay() {
			window.clearInterval(autoplayId);
			if (!isMobileCarousel()) return;
			autoplayId = window.setInterval(() => renderTestimonials(activeSlide + 1), 3000);
		}

		prevButton?.addEventListener('click', () => {
			renderTestimonials(activeSlide - 1);
			startAutoplay();
		});

		nextButton?.addEventListener('click', () => {
			renderTestimonials(activeSlide + 1);
			startAutoplay();
		});

		testimonialDots.forEach((dot) => {
			dot.addEventListener('click', () => {
				const index = Number(dot.dataset.index ?? 0);
				renderTestimonials(index);
				startAutoplay();
			});
		});

		window.addEventListener('resize', () => {
			renderTestimonials(activeSlide);
			startAutoplay();
		});

		renderTestimonials(0);
		startAutoplay();
	</script>

	<section class="experience bg-coastal textured">
		<div class="container">
			<div class="section-header section-header-dark">
				<span class="section-kicker">Welcome In</span>
			</div>
			<div class="experience-block">
				<div class="experience-visual">
					<img src={`${import.meta.env.BASE_URL}assets/amenities/exterior.jpg`} alt="Saco Bay Hotel exterior building in Saco Maine" />
				</div>
					<div class="experience-content">
					<h2 class="experience-heading"><span class="serif-italic">Your Home Base</span></h2>
					<p>We are in Saco, close to Old Orchard Beach, Camp Ellis, Ferry Beach, and downtown Biddeford. If you know the area, you know that means you can get to just about everything without making a whole day out of the drive.</p>
					<p>This is a good spot for beach weekends, family trips, and a few days on the coast when you want a clean room, an easy place to park, and no nonsense.</p>
					<a href="https://us2.cloudbeds.com/en/reservation/wOOQW0?currency=usd&adults=2&kids=0" class="btn-primary" data-booking-link>Book Now</a>
				</div>
			</div>
		</div>
	</section>

	<section id="rooms" class="suites-vertical-gallery bg-navy">
		<div class="rooms-intro container section-header section-header-light">
			<span class="section-kicker">Our Rooms</span>
		</div>

		<div class="rooms-carousel-shell rooms-carousel-desktop">
			<button class="rooms-nav prev" type="button" aria-label="Previous room">‹</button>
			<div class="rooms-carousel-viewport">
				<div class="rooms-carousel-track">
					{
						roomSlides.map((room) => (
							<article class="room-slide" data-room={room.id}>
								<div class="room-slide-image">
									<img src={room.image} alt={room.alt} />
								</div>
								<div class="room-slide-caption">
									<div>
										<span class="eyebrow">{room.eyebrow}</span>
										<h2>{room.title}</h2>
										<p>{room.summary}</p>
									</div>
									<a href={roomsHref} class="room-see-more">
										See More <span aria-hidden="true">→</span>
									</a>
								</div>
							</article>
						))
					}
				</div>
			</div>
			<button class="rooms-nav next" type="button" aria-label="Next room">›</button>
		</div>
		<div class="rooms-carousel-dots" aria-label="Rooms pagination">
			{
				roomSlides.map((_, index) => (
					<button
						type="button"
						class={`rooms-dot${index === 0 ? ' is-active' : ''}`}
						data-index={index}
						aria-label={`Go to room ${index + 1}`}
					></button>
				))
			}
		</div>

		<div class="rooms-mobile-shell">
			<button class="rooms-mobile-nav prev" type="button" aria-label="Previous room">‹</button>
			<div class="rooms-mobile-viewport">
				<div class="rooms-mobile-stack">
					{
						roomSlides.map((room) => (
							<article class="room-mobile-card">
								<div class="room-mobile-image">
									<img src={room.image} alt={room.alt} />
								</div>
								<div class="room-mobile-content">
									<span class="eyebrow">{room.eyebrow}</span>
									<h2>{room.title}</h2>
									<p>{room.summary}</p>
									<a href={roomsHref} class="room-see-more">
										See More <span aria-hidden="true">→</span>
									</a>
								</div>
							</article>
						))
					}
				</div>
			</div>
			<button class="rooms-mobile-nav next" type="button" aria-label="Next room">›</button>
		</div>
		<div class="rooms-mobile-dots" aria-label="Mobile rooms pagination">
			{
				roomSlides.map((_, index) => (
					<button
						type="button"
						class={`rooms-mobile-dot${index === 0 ? ' is-active' : ''}`}
						data-index={index}
						aria-label={`Go to mobile room ${index + 1}`}
					></button>
				))
			}
		</div>
	</section>

	<script>
		const roomsTrack = document.querySelector('.rooms-carousel-track') as HTMLElement | null;
		const roomsViewport = document.querySelector('.rooms-carousel-viewport') as HTMLElement | null;
		const mobileRoomsViewport = document.querySelector('.rooms-mobile-viewport') as HTMLElement | null;
		const roomDots = Array.from(document.querySelectorAll('.rooms-dot')) as HTMLButtonElement[];
		const roomPrevButton = document.querySelector('.rooms-nav.prev') as HTMLButtonElement | null;
		const roomNextButton = document.querySelector('.rooms-nav.next') as HTMLButtonElement | null;
		const mobileRoomCards = Array.from(document.querySelectorAll('.room-mobile-card')) as HTMLElement[];
		const mobileRoomDots = Array.from(document.querySelectorAll('.rooms-mobile-dot')) as HTMLButtonElement[];
		const mobileRoomPrevButton = document.querySelector('.rooms-mobile-nav.prev') as HTMLButtonElement | null;
		const mobileRoomNextButton = document.querySelector('.rooms-mobile-nav.next') as HTMLButtonElement | null;
		let activeRoom = 0;
		let mobileRoomTouchStartX = 0;
		let mobileRoomTouchStartY = 0;

		function renderRoomSlide(index: number) {
			if (window.innerWidth <= 1024) {
				if (mobileRoomCards.length === 0) return;

				activeRoom = (index + mobileRoomCards.length) % mobileRoomCards.length;
				mobileRoomCards.forEach((card, cardIndex) => {
					card.classList.remove('is-active', 'is-before', 'is-after');
					if (cardIndex === activeRoom) {
						card.classList.add('is-active');
					} else if (cardIndex === (activeRoom - 1 + mobileRoomCards.length) % mobileRoomCards.length) {
						card.classList.add('is-before');
					} else {
						card.classList.add('is-after');
					}
				});

				mobileRoomDots.forEach((dot, dotIndex) => {
					dot.classList.toggle('is-active', dotIndex === activeRoom);
				});

				return;
			}

			if (!roomsTrack || !roomsViewport) return;

			activeRoom = (index + roomDots.length) % roomDots.length;
			const slideWidth = roomsViewport.clientWidth;
			roomsTrack.style.transform = `translateX(-${activeRoom * slideWidth}px)`;

			roomDots.forEach((dot, dotIndex) => {
				dot.classList.toggle('is-active', dotIndex === activeRoom);
			});
		}

		roomPrevButton?.addEventListener('click', () => {
			renderRoomSlide(activeRoom - 1);
		});

		roomNextButton?.addEventListener('click', () => {
			renderRoomSlide(activeRoom + 1);
		});

		roomDots.forEach((dot) => {
			dot.addEventListener('click', () => {
				renderRoomSlide(Number(dot.dataset.index ?? 0));
			});
		});

		mobileRoomPrevButton?.addEventListener('click', () => {
			renderRoomSlide(activeRoom - 1);
		});

		mobileRoomNextButton?.addEventListener('click', () => {
			renderRoomSlide(activeRoom + 1);
		});

		mobileRoomDots.forEach((dot) => {
			dot.addEventListener('click', () => {
				renderRoomSlide(Number(dot.dataset.index ?? 0));
			});
		});

		mobileRoomsViewport?.addEventListener(
			'touchstart',
			(event) => {
				const touch = event.touches[0];
				if (!touch) return;
				mobileRoomTouchStartX = touch.clientX;
				mobileRoomTouchStartY = touch.clientY;
			},
			{ passive: true }
		);

		mobileRoomsViewport?.addEventListener(
			'touchend',
			(event) => {
				const touch = event.changedTouches[0];
				if (!touch || window.innerWidth > 1024) return;

				const deltaX = touch.clientX - mobileRoomTouchStartX;
				const deltaY = touch.clientY - mobileRoomTouchStartY;
				const swipeThreshold = 40;

				if (Math.abs(deltaX) <= swipeThreshold || Math.abs(deltaX) <= Math.abs(deltaY)) return;

				if (deltaX < 0) {
					renderRoomSlide(activeRoom + 1);
				} else {
					renderRoomSlide(activeRoom - 1);
				}
			},
			{ passive: true }
		);

		window.addEventListener('resize', () => {
			renderRoomSlide(activeRoom);
		});

		renderRoomSlide(0);
	</script>

	<section id="amenities" class="amenities-magazine bg-mist textured">
		<div class="container">
			<div class="section-header section-header-dark">
				<span class="section-kicker">Our Amenities</span>
			</div>
			<div class="amenities-magazine-layout">
				<div class="amenity-visual">
					<div class="visual-stack">
						<div class="visual-main" style={`background-image: url('${import.meta.env.BASE_URL}assets/amenities/lobby.jpg')`}></div>
						<div class="visual-accent"></div>
					</div>
				</div>
				<div class="amenity-content-right">
					<h2 class="amenity-heading">The Stuff <span class="serif-italic">That Matters</span></h2>
					<div class="amenities-feature-card">
						<div class="amenities-summary-grid">
							<p class="amenity-subtext">Hot breakfast in the morning, free parking, fast WiFi, and the basics handled so you can get on with your trip to Main St or OOB.</p>
							<div class="amenities-summary-side">
								<ul class="amenity-highlight-list">
									<li>Hot breakfast included daily</li>
									<li>Free on-site parking</li>
									<li>24-hour airport shuttle</li>
									<li>Fast, reliable WiFi</li>
								</ul>
							</div>
								<a href={experienceHref} class="amenity-detail-link">See the full list of our amenities & attractions →</a>
						</div>
					</div>
				</div>
			</div>
	</section>

	<section id="location" class="location-map-style">
		<div class="container">
			<div class="section-header section-header-dark location-section-header">
				<span class="section-kicker">Our Location</span>
			</div>
			<div class="location-map-grid">
				<div class="location-map-info">
					<div class="location-hotel-visual">
						<img src={`${import.meta.env.BASE_URL}assets/location/building.jpg`} alt="Saco Bay Hotel exterior building in Saco Maine" />
					</div>
					<div class="location-text-content">
						<h2 class="location-heading">Where to Find Us</h2>
						<p>You will find us at 352 North Street in Saco, just a short drive from Old Orchard Beach, Camp Ellis, downtown Saco, and Biddeford. It is an easy spot to use as a base if you want the beach nearby but do not want to be stuck right in the middle of the summer crowd.</p>

