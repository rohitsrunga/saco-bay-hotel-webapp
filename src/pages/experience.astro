---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import exteriorPropertyImg from '../assets/gallery/exterior_property.jpg';
import checkInImg from '../assets/gallery/check_in_area_lobby.jpg';
import relaxAreaImg from '../assets/gallery/relax_area_lobby.jpg';
import breakfastAreaImg from '../assets/gallery/breakfast_area.jpg';
import kingBedImg from '../assets/gallery/king_bed.jpg';
import twoQueenImg from '../assets/gallery/2_queen_room.jpg';
import deskAreaImg from '../assets/gallery/room_desk_working_area.jpg';
import tvCouchImg from '../assets/gallery/room_tv_desk_couch_.jpg';
import suiteCommonImg from '../assets/gallery/suite_common_area.jpg';
import bathroomImg from '../assets/gallery/bathroom.jpg';
import foodImg from '../assets/amenities/food.jpg';
import exteriorImg from '../assets/amenities/exterior.jpg';

const gallerySlides = [
	{
		id: 'exterior',
		title: 'Out Front',
		image: exteriorPropertyImg,
		alt: 'Exterior view of Saco Bay Hotel in Saco Maine',
		caption: 'A look at the property from outside, with easy parking and a simple setup for coming and going.'
	},
	{
		id: 'check-in',
		title: 'Lobby Check-In',
		image: checkInImg,
		alt: 'Check-in area and lobby at Saco Bay Hotel',
		caption: 'The front desk and main lobby area, where your stay starts without much fuss.'
	},
	{
		id: 'lobby-seating',
		title: 'Lobby Seating',
		image: relaxAreaImg,
		alt: 'Lobby seating area at Saco Bay Hotel',
		caption: 'A quiet corner in the lobby to sit for a bit, meet up with family, or plan the rest of the day.'
	},
	{
		id: 'breakfast',
		title: 'Breakfast Area',
		image: breakfastAreaImg,
		alt: 'Breakfast area at Saco Bay Hotel',
		caption: 'The breakfast room where guests can grab something easy before heading out toward the beach or the road.'
	},
	{
		id: 'king-room',
		title: 'King Room',
		image: kingBedImg,
		alt: 'King bed guest room at Saco Bay Hotel',
		caption: 'A king room with a clean setup and enough space to settle in after a day around Saco or Old Orchard.'
	},
	{
		id: 'two-queen',
		title: 'Two Queen Room',
		image: twoQueenImg,
		alt: 'Two queen room at Saco Bay Hotel',
		caption: 'A two-queen room that works well for families, friends, or anyone needing a little more sleeping space.'
	},
	{
		id: 'desk-area',
		title: 'Desk And Work Area',
		image: deskAreaImg,
		alt: 'Guest room desk and work area at Saco Bay Hotel',
		caption: 'A room setup with a desk and workspace if you need to answer email before heading back out.'
	},
	{
		id: 'tv-couch',
		title: 'Room Lounge Area',
		image: tvCouchImg,
		alt: 'Guest room with television, desk, and couch at Saco Bay Hotel',
		caption: 'Extra room to sit back, watch a show, or just take a break once you are in for the night.'
	},
	{
		id: 'suite-common',
		title: 'Suite Living Space',
		image: suiteCommonImg,
		alt: 'Suite common area at Saco Bay Hotel',
		caption: 'The suite living area, with more elbow room if you want something beyond a standard room.'
	},
	{
		id: 'bathroom',
		title: 'Guest Bathroom',
		image: bathroomImg,
		alt: 'Guest bathroom at Saco Bay Hotel',
		caption: 'One of the guest bathrooms, set up clean and simple with the basics close at hand.'
	}
];

const amenityGroups = [
	{
		title: 'The Essentials',
		description: 'The basics that make a stay easy, whether you are here for the beach, visiting family, or just getting away for a couple days.',
		image: foodImg,
		imageAlt: 'Hot breakfast included at Saco Bay Hotel',
		items: [
			'Hot breakfast included every morning',
			'Outdoor Pool',
			'Conference Center & Meeting Rooms',
			'Complimentary on-site parking',
			'Fast WiFi',
			'Refrigerator and microwave',
			'Keurig coffee makers',
			'Plush bedding and linens',
			'Dedicated work surface in all rooms',
			'Park & Fly'
		]
	},
	{
		title: 'Around the Area',
		description: 'You are close to more than just Old Orchard. Saco, Biddeford, Camp Ellis, and the beaches all give you plenty to do without a long drive.',
		image: exteriorImg,
		imageAlt: 'Saco Bay Hotel exterior in Saco, Maine',
		items: [
			'Old Orchard Beach pier, boardwalk, and Palace Playland · 3 mi, 7 min',
			"Funtown Splashtown USA · Maine's largest amusement and water park · 1.5 mi, 5 min",
			'Ferry Beach State Park for swimming and nature trails · 2 mi, 6 min',
			'Saco River for kayaking and canoe launches · 3 mi, 7 min',
			'Camp Ellis beach and the Saco Bay jetty walk · 4 mi, 9 min',
			'East Point Sanctuary in Biddeford Pool for birding and coastal views · 8 mi, 15 min',
			'Scarborough Marsh, the largest salt marsh in Maine · 7 mi, 12 min',
			"Downtown Biddeford's restaurant and arts scene · 4 mi, 10 min",
			'Portland Head Light · 22 mi, 30 min',
			'Portland Old Port · 20 mi, 28 min'
		]
	}
];

const faqs = [
	{
		question: 'Breakfast',
		answer: 'Hot breakfast is included every morning, with the usual staples to get you out the door without having to make your first stop a coffee shop.'
	},
	{
		question: 'Pets',
		answer: 'We do not allow pets, with the exception of ADA service animals.'
	},
	{
		question: 'Check-in / Check-out',
		answer: 'Standard check-in is at 3pm and check-out is at 11am.'
	},
	{
		question: 'Parking',
		answer: 'Parking is free and right on site. No garage, no pass to fuss with, no extra charge.'
	},
	{
		question: 'Park & Fly',
		answer: 'If you are flying out of PWM, this is an easy place to stay the night before so you are not driving half-asleep to the airport.'
	},
	{
		question: 'Getting around',
		answer: 'Old Orchard Beach is a quick drive. Downtown Saco and Biddeford are close by, and Portland is far enough north to be doable without needing to stay there. If you want local food or beach suggestions, just ask.'
	}
];
---

<Layout title="Amenities & Local Attractions | Saco Bay Hotel" description="Explore Saco Bay Hotel's amenities and the best things to do near Old Orchard Beach, Maine — beaches, amusement parks, trails, and dining.">
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": [
			{
				"@type": "Question",
				"name": "Does Saco Bay Hotel include breakfast?",
				"acceptedAnswer": { "@type": "Answer", "text": "Yes. Hot breakfast is included every morning, with the usual staples to get you out the door without having to make your first stop a coffee shop." }
			},
			{
				"@type": "Question",
				"name": "Are pets allowed at Saco Bay Hotel?",
				"acceptedAnswer": { "@type": "Answer", "text": "Saco Bay Hotel does not allow pets, with the exception of ADA service animals." }
			},
			{
				"@type": "Question",
				"name": "What time is check-in and check-out at Saco Bay Hotel?",
				"acceptedAnswer": { "@type": "Answer", "text": "Standard check-in is at 3:00 PM and check-out is at 11:00 AM." }
			},
			{
				"@type": "Question",
				"name": "Is parking free at Saco Bay Hotel?",
				"acceptedAnswer": { "@type": "Answer", "text": "Yes. Parking is free and right on site. No garage, no pass to fuss with, no extra charge." }
			},
			{
				"@type": "Question",
				"name": "Does Saco Bay Hotel offer Park and Fly?",
				"acceptedAnswer": { "@type": "Answer", "text": "Yes. Saco Bay Hotel offers Park & Fly. If you are flying out of Portland International Jetport (PWM), it is an easy place to stay the night before so you are not driving half-asleep to the airport." }
			},
			{
				"@type": "Question",
				"name": "How far is Saco Bay Hotel from Old Orchard Beach?",
				"acceptedAnswer": { "@type": "Answer", "text": "Old Orchard Beach is about 3 miles away — a quick 7-minute drive from Saco Bay Hotel." }
			},
			{
				"@type": "Question",
				"name": "How far is Saco Bay Hotel from Portland, Maine?",
				"acceptedAnswer": { "@type": "Answer", "text": "Portland, Maine is approximately 20 miles north — about a 28-minute drive from Saco Bay Hotel." }
			}
		]
	})} />
	<section class="experience-hero bg-warm">
		<div class="container experience-hero-inner">
			<span class="eyebrow">Saco Bay Hotel</span>
			<h1>The Experience</h1>
			<p>What you need to know before you book, plus a few good ways to spend your time once you get here.</p>
		</div>
	</section>

	<section class="experience-gallery bg-navy">
		<div class="container">
			<div class="gallery-intro section-heading section-heading-light">
				<span class="eyebrow">Part 1</span>
				<h2>Gallery</h2>
				<p>A look around our hotel, from the lobby to the guest rooms.</p>
			</div>
		</div>

		<div class="container">
			<div class="gallery-carousel-shell gallery-carousel-desktop">
				<button class="gallery-nav prev" type="button" aria-label="Previous gallery photo">‹</button>
				<div class="gallery-carousel-viewport">
					<div class="gallery-carousel-track">
						{
							gallerySlides.map((slide) => (
								<article class="gallery-slide" data-gallery={slide.id}>
									<div class="gallery-slide-image">
										<Image src={slide.image} alt={slide.alt} loading="lazy" width={1200} height={800} />
									</div>
									<div class="gallery-slide-caption">
										<div>
											<span class="eyebrow">{slide.title}</span>
											<p>{slide.caption}</p>
										</div>
									</div>
								</article>
							))
						}
					</div>
				</div>
				<button class="gallery-nav next" type="button" aria-label="Next gallery photo">›</button>
			</div>
			<div class="gallery-carousel-dots" aria-label="Gallery pagination">
				{
					gallerySlides.map((slide, index) => (
						<button
							type="button"
							class={`gallery-dot${index === 0 ? ' is-active' : ''}`}
							data-index={index}
							aria-label={`Go to ${slide.title}`}
						></button>
					))
				}
			</div>

			<div class="gallery-mobile-shell">
				<button class="gallery-mobile-nav prev" type="button" aria-label="Previous gallery photo">‹</button>
				<div class="gallery-mobile-viewport">
					<div class="gallery-mobile-stack">
						{
							gallerySlides.map((slide, index) => (
								<article class={`gallery-mobile-card${index === 0 ? ' is-active' : ''}`}>
									<div class="gallery-mobile-image">
										<Image src={slide.image} alt={slide.alt} loading="lazy" width={1200} height={800} />
									</div>
									<div class="gallery-mobile-content">
										<span class="eyebrow">{slide.title}</span>
										<p>{slide.caption}</p>
									</div>
								</article>
							))
						}
					</div>
				</div>
				<button class="gallery-mobile-nav next" type="button" aria-label="Next gallery photo">›</button>
			</div>
			<div class="gallery-mobile-dots" aria-label="Mobile gallery pagination">
				{
					gallerySlides.map((slide, index) => (
						<button
							type="button"
							class={`gallery-mobile-dot${index === 0 ? ' is-active' : ''}`}
							data-index={index}
							aria-label={`Go to ${slide.title}`}
						></button>
					))
				}
			</div>
		</div>
	</section>

	<script>
		const galleryTrack = document.querySelector('.gallery-carousel-track') as HTMLElement | null;
		const galleryViewport = document.querySelector('.gallery-carousel-viewport') as HTMLElement | null;
		const galleryDots = Array.from(document.querySelectorAll('.gallery-dot')) as HTMLButtonElement[];
		const galleryPrevButton = document.querySelector('.gallery-nav.prev') as HTMLButtonElement | null;
		const galleryNextButton = document.querySelector('.gallery-nav.next') as HTMLButtonElement | null;
		const mobileGalleryViewport = document.querySelector('.gallery-mobile-viewport') as HTMLElement | null;
		const mobileGalleryCards = Array.from(document.querySelectorAll('.gallery-mobile-card')) as HTMLElement[];
		const mobileGalleryDots = Array.from(document.querySelectorAll('.gallery-mobile-dot')) as HTMLButtonElement[];
		const mobileGalleryPrevButton = document.querySelector('.gallery-mobile-nav.prev') as HTMLButtonElement | null;
		const mobileGalleryNextButton = document.querySelector('.gallery-mobile-nav.next') as HTMLButtonElement | null;
		let activeGallery = 0;
		let galleryTouchStartX = 0;
		let galleryTouchStartY = 0;

		function renderGallerySlide(index: number) {
			if (window.innerWidth <= 1024) {
				if (mobileGalleryCards.length === 0) return;

				activeGallery = (index + mobileGalleryCards.length) % mobileGalleryCards.length;
				mobileGalleryCards.forEach((card, cardIndex) => {
					card.classList.remove('is-active', 'is-before', 'is-after');
					if (cardIndex === activeGallery) {
						card.classList.add('is-active');
					} else if (cardIndex === (activeGallery - 1 + mobileGalleryCards.length) % mobileGalleryCards.length) {
						card.classList.add('is-before');
					} else {
						card.classList.add('is-after');
					}
				});

				mobileGalleryDots.forEach((dot, dotIndex) => {
					dot.classList.toggle('is-active', dotIndex === activeGallery);
				});

				return;
			}

			if (!galleryTrack || !galleryViewport) return;

			activeGallery = (index + galleryDots.length) % galleryDots.length;
			const slideWidth = galleryViewport.clientWidth;
			galleryTrack.style.transform = `translateX(-${activeGallery * slideWidth}px)`;

			galleryDots.forEach((dot, dotIndex) => {
				dot.classList.toggle('is-active', dotIndex === activeGallery);
			});
		}

		galleryPrevButton?.addEventListener('click', () => {
			renderGallerySlide(activeGallery - 1);
		});

		galleryNextButton?.addEventListener('click', () => {
			renderGallerySlide(activeGallery + 1);
		});

		galleryDots.forEach((dot) => {
			dot.addEventListener('click', () => {
				renderGallerySlide(Number(dot.dataset.index ?? 0));
			});
		});

		mobileGalleryPrevButton?.addEventListener('click', () => {
			renderGallerySlide(activeGallery - 1);
		});

		mobileGalleryNextButton?.addEventListener('click', () => {
			renderGallerySlide(activeGallery + 1);
		});

		mobileGalleryDots.forEach((dot) => {
			dot.addEventListener('click', () => {
				renderGallerySlide(Number(dot.dataset.index ?? 0));
			});
		});

		mobileGalleryViewport?.addEventListener(
			'touchstart',
			(event) => {
				const touch = event.touches[0];
				if (!touch) return;
				galleryTouchStartX = touch.clientX;
				galleryTouchStartY = touch.clientY;
			},
			{ passive: true }
		);

		mobileGalleryViewport?.addEventListener(
			'touchend',
			(event) => {
				const touch = event.changedTouches[0];
				if (!touch || window.innerWidth > 1024) return;

				const deltaX = touch.clientX - galleryTouchStartX;
				const deltaY = touch.clientY - galleryTouchStartY;
				const swipeThreshold = 40;

				if (Math.abs(deltaX) <= swipeThreshold || Math.abs(deltaX) <= Math.abs(deltaY)) return;

				if (deltaX < 0) {
					renderGallerySlide(activeGallery + 1);
				} else {
					renderGallerySlide(activeGallery - 1);
				}
			},
			{ passive: true }
		);

		window.addEventListener('resize', () => {
			renderGallerySlide(activeGallery);
		});

		renderGallerySlide(0);
	</script>

	<section class="experience-detail bg-coastal textured">
		<div class="container">
			<div class="section-heading">
				<span class="eyebrow">Part 2</span>
				<h2 class="navy-text">Amenities</h2>
				<p>The useful stuff. Nothing fancy for the sake of it, just the things most people want when they are staying near the coast.</p>
			</div>

			<div class="amenities-editorial-grid">
				{
					amenityGroups.map((group) => (
						<article class="amenity-group">
							{group.image && (
								<figure class="amenity-group-photo">
									<Image
										src={group.image}
										alt={group.imageAlt}
										loading="lazy"
										width={800}
										height={534}
									/>
								</figure>
							)}
							<div class="amenity-group-header">
								<h3>{group.title}</h3>
								<p>{group.description}</p>
							</div>
							{group.highlight && (
								<div class="amenity-highlight">
									<span class="sans-caps">Highlighted</span>
									<h4>{group.highlight}</h4>
									<p>Stay before your flight, leave your car here while you travel, and use our 24-hour shuttle to get to PWM without the usual airport scramble.</p>
								</div>
							)}
							<ul>
								{group.items.map((item) => <li>{item}</li>)}
							</ul>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="faq-section bg-warm">
		<div class="container faq-layout">
			<div class="section-heading faq-heading">
				<span class="eyebrow">Part 3</span>
				<h2 class="navy-text">Good to Know</h2>
				<p>A few quick answers before you head this way.</p>
			</div>

			<div class="faq-list">
				{
					faqs.map((faq, index) => (
						<details class="faq-item" open={index === 0}>
							<summary>{faq.question}</summary>
							<p>{faq.answer}</p>
						</details>
					))
				}
			</div>
		</div>
	</section>
</Layout>

<style>
	.experience-hero {
		padding: 11rem 0 5rem;
	}

	.experience-hero-inner {
		max-width: 860px;
	}

	.experience-hero h1 {
		font-size: clamp(3.8rem, 9vw, 6.5rem);
		line-height: 0.95;
		color: var(--navy-deep);
		margin-bottom: 1.5rem;
	}

	.experience-hero p {
		max-width: 620px;
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--text-muted);
	}

	.experience-gallery {
		padding: 0 0 3rem;
		position: relative;
	}

	.gallery-intro {
		padding-top: 5.5rem;
		padding-bottom: 1.5rem;
		position: relative;
		z-index: 2;
		margin-bottom: 1.5rem;
	}

	.gallery-intro .eyebrow,
	.gallery-intro h2,
	.gallery-intro p {
		color: var(--white);
	}

	.gallery-intro p {
		max-width: 42rem;
		color: #6A85A8;
	}

	.gallery-carousel-shell {
		position: relative;
		width: 100%;
		height: 100%;
		padding: 0 6rem;
	}

	.gallery-carousel-viewport {
		width: 100%;
		overflow: hidden;
	}

	.gallery-carousel-track {
		display: flex;
		flex-wrap: nowrap;
		width: 100%;
		transition: transform 0.55s ease;
		will-change: transform;
	}

	.gallery-slide {
		flex: 0 0 100%;
		min-width: 100%;
		width: 100%;
		display: flex;
		flex-direction: column;
	}

	.gallery-slide-image img {
		display: block;
		width: 100%;
		height: 100%;
		min-height: 500px;
		max-height: 620px;
		object-fit: cover;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: 0 18px 42px rgba(30, 45, 75, 0.16);
	}

	.gallery-slide-caption {
		margin-top: 1.15rem;
		padding: 1.1rem 0.25rem 0;
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 2rem;
	}

	.gallery-slide-caption .eyebrow,
	.gallery-mobile-content .eyebrow {
		color: #7A9DC4;
		margin-bottom: 0.55rem;
	}

	.gallery-slide-caption p,
	.gallery-mobile-content p {
		font-size: 0.98rem;
		line-height: 1.7;
		color: #6A85A8;
		max-width: 38rem;
	}

	.gallery-nav {
		position: absolute;
		top: 250px;
		transform: translateY(-50%);
		width: 2.45rem;
		height: 2.45rem;
		border: 1px solid rgba(255, 255, 255, 0.28);
		background: rgba(255, 255, 255, 0.08);
		color: var(--white);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 1.2rem;
		line-height: 1;
		cursor: pointer;
		z-index: 3;
		backdrop-filter: blur(10px);
	}

	.gallery-nav.prev {
		left: 1rem;
	}

	.gallery-nav.next {
		right: 1rem;
	}

	.gallery-carousel-dots {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.7rem;
		margin-top: 0.75rem;
	}

	.gallery-dot {
		width: 0.72rem;
		height: 0.72rem;
		border-radius: 999px;
		border: none;
		background: rgba(255, 255, 255, 0.28);
		cursor: pointer;
		padding: 0;
	}

	.gallery-dot.is-active {
		background: var(--white);
	}

	.gallery-carousel-desktop {
		display: block;
	}

	.gallery-mobile-stack {
		display: none;
	}

	.gallery-mobile-shell,
	.gallery-mobile-dots {
		display: none;
	}

	.gallery-mobile-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.gallery-mobile-content {
		padding: 1rem 0.35rem 0;
	}

	.section-heading {
		max-width: 720px;
		margin-bottom: 4rem;
		position: relative;
		z-index: 2;
	}

	.section-heading h2 {
		font-size: 3.5rem;
		margin-bottom: 1rem;
	}

	.section-heading p {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--text-muted);
	}

	.amenities-editorial-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
		position: relative;
		z-index: 2;
	}

	.amenity-group {
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(30, 45, 75, 0.08);
		box-shadow: 0 18px 45px rgba(30, 45, 75, 0.08);
		backdrop-filter: blur(10px);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		overflow: hidden;
	}

	.amenity-group-photo {
		margin: 0;
		line-height: 0;
		overflow: hidden;
	}

	.amenity-group-photo img {
		display: block;
		width: 100%;
		height: 220px;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.amenity-group:hover .amenity-group-photo img {
		transform: scale(1.02);
	}

	.amenity-group-header,
	.amenity-group ul {
		padding: 0 2rem;
	}

	.amenity-group ul {
		padding-bottom: 2rem;
	}

	.amenity-group-header {
		padding-top: 2rem;
	}

	.amenity-group-header h3 {
		font-size: 2rem;
		color: var(--navy-deep);
		margin-bottom: 0.75rem;
	}

	.amenity-group-header p,
	.amenity-highlight p {
