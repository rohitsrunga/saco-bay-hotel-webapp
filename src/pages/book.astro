---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book Direct | Saco Bay Hotel — Best Rate Guaranteed" description="Book your stay directly at Saco Bay Hotel in Saco, Maine. Best rate guaranteed. Minutes from Old Orchard Beach and the southern Maine coast." minimalHeader={true}>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Offer",
		"name": "Best Rate Guaranteed — Book Direct",
		"description": "Book direct at Saco Bay Hotel for the best available rate on rooms near Old Orchard Beach, Maine. No booking fees.",
		"url": "https://sacobayhotel.com/book",
		"availability": "https://schema.org/InStock",
		"seller": {
			"@type": "LodgingBusiness",
			"name": "Saco Bay Hotel",
			"url": "https://sacobayhotel.com",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "352 North St",
				"addressLocality": "Saco",
				"addressRegion": "ME",
				"postalCode": "04072",
				"addressCountry": "US"
			}
		}
	})} />
	<div class="book-page">
		<cb-immersive-experience property-code="wOOQW0" mode="standard"></cb-immersive-experience>
	</div>
</Layout>

<style>
	.book-page {
		padding-top: var(--header-height);
		min-height: 100vh;
		background: var(--white);
	}

</style>

<style is:global>
	body:has(.book-page) {
		background: var(--white);
	}

	body:has(.book-page) main {
		overflow-x: clip;
	}

	/* Fully isolate Cloudbeds widget from all our custom CSS */
	cb-immersive-experience,
	cb-immersive-experience *,
	cb-immersive-experience *::before,
	cb-immersive-experience *::after {
		all: revert;
	}

	body:has(.book-page) #main-header .header-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	body:has(.book-page) #main-header .header-center {
		display: none;
	}

	/* On scroll, fully remove the header visually and from pointer events */
	body:has(.book-page) #main-header.hide-home-badge {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	@media (max-width: 768px) {
		body:has(.book-page) #main-header.scrolled .header-left,
		body:has(.book-page) #main-header.scrolled .header-right {
			position: relative;
			top: auto;
			transform: none;
		}
	}
</style>
