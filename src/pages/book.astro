---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book Your Stay | Saco Bay Hotel" description="Book your stay at Saco Bay Hotel in Saco, Maine, near Old Orchard Beach and the southern Maine coast." minimalHeader={true}>
	<div class="book-page">
		<cb-immersive-experience property-code="wOOQW0" mode="standard"></cb-immersive-experience>
	</div>
</Layout>

<style>
	.book-page {
		padding-top: var(--header-height);
		min-height: 100vh;
		background: var(--white);
	}

	.book-page cb-immersive-experience {
		display: block;
		width: 100%;
		font-family: Inter, system-ui, sans-serif;
		line-height: normal;
	}
</style>

<style is:global>
	body:has(.book-page) {
		background: var(--white);
	}

	body:has(.book-page) main {
		overflow-x: clip;
	}

	/* Prevent global reset from stripping spacing inside Cloudbeds widget */
	cb-immersive-experience *,
	cb-immersive-experience *::before,
	cb-immersive-experience *::after {
		margin: revert;
		padding: revert;
		box-sizing: revert;
		line-height: revert;
		font-family: revert;
		font-weight: revert;
		color: revert;
	}

	body:has(.book-page) #main-header .header-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	body:has(.book-page) #main-header .header-center {
		display: none;
	}

	body:has(.book-page) #main-header.nav-hidden .header-left,
	body:has(.book-page) #main-header.nav-hidden .header-right {
		opacity: 0;
		pointer-events: none;
	}

	body:has(.book-page) #main-header .header-left,
	body:has(.book-page) #main-header .header-right {
		transition: opacity 0.4s ease;
	}

	@media (max-width: 768px) {
		body:has(.book-page) #main-header.scrolled .header-left,
		body:has(.book-page) #main-header.scrolled .header-right {
			position: relative;
			top: auto;
			transform: none;
		}
	}
</style>

<script>
	const header = document.getElementById('main-header');

	window.addEventListener('scroll', () => {
		header?.classList.toggle('nav-hidden', window.scrollY > 40);
	}, { passive: true });
</script>
