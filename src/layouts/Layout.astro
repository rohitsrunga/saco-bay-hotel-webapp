---
interface Props {
	title: string;
	description?: string;
	minimalHeader?: boolean;
}

import '../styles/global.css';

const { title, description = "Saco Bay Hotel in Saco, Maine, near Old Orchard Beach and the southern Maine coast.", minimalHeader = false } = Astro.props;
const normalizePath = (value: string) => {
	if (!value || value === '/') return '';
	return value.endsWith('/') ? value.slice(0, -1) : value;
};

const baseUrl = import.meta.env.BASE_URL;
const basePath = normalizePath(baseUrl);
const pathname = normalizePath(Astro.url.pathname);
const isHome = pathname === basePath || pathname === `${basePath}/index.html`;
const homeHref = baseUrl;
const roomsHref = `${baseUrl}rooms`;
const experienceHref = `${baseUrl}experience`;
const homeBookingHref = `${baseUrl}#home`;
const locationHref = isHome ? '#location' : `${baseUrl}#location`;

---

<!doctype html>
<html lang="en">
	<head>
		<script type="text/javascript" src="https://static1.cloudbeds.com/booking-engine/latest/static/js/immersive-experience/cb-immersive-experience.js"></script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
	</head>
	<body>
		<header id="main-header" class={isHome ? "" : "scrolled"}>
				<div class="header-container">
					<div class="header-left">
						<a href={homeHref} class="nav-brand-link">
							<span class="nav-brand-text">Saco Bay Hotel</span>
						</a>
						<nav class="main-nav left-nav">
							<a href={roomsHref}>Rooms</a>
							<a href={experienceHref}>Experience</a>
						</nav>
					</div>
				<div class="header-center">
					<a href={homeHref} class="logo-full">
						<span class="logo-text">Saco Bay Hotel</span>
					</a>
				</div>
				<div class="header-right">
					<nav class="main-nav right-nav">
						<a href={locationHref}>Location</a>
						<div class="header-actions">
							<button id="menu-toggle" class="menu-trigger" aria-label="Toggle Menu">
								<span class="hamburger-line"></span>
								<span class="hamburger-line"></span>
								<span class="hamburger-line"></span>
							</button>
							{!minimalHeader && <a href="/book" class="btn-book">Book Now</a>}
						</div>
					</nav>
				</div>
			</div>
		</header>

		<nav id="full-menu" class="menu-dropdown">
			<div class="menu-dropdown-content">
				<div class="menu-links">
					<a href={homeHref} class="menu-link">Home</a>
					<a href={roomsHref} class="menu-link">Rooms</a>
					<a href={experienceHref} class="menu-link">Experience</a>
					<a href={locationHref} class="menu-link">Location</a>
					<a href="/book" class="menu-link menu-link-book">Book Now</a>
				</div>
				<div class="menu-dropdown-footer">
					<p>352 North St, Saco, ME 04072</p>
					<p>-</p>
					<p>(207) 747-0368</p>
				</div>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer>
			<div class="container footer-content">
				<div class="footer-top">
					<div class="footer-brand">
						<h3 class="logo-text footer-logo" style="color: var(--navy-deep);">Saco Bay Hotel</h3>
						<p class="address">352 North St, Saco, ME 04072</p>
						<p class="phone">(207) 747-0368</p>
					</div>
					<nav class="footer-nav">
						<div class="footer-nav-col">
							<h4>Explore</h4>
							<a href={experienceHref}>Experience</a>
							<a href={locationHref}>Location</a>
						</div>
						<div class="footer-nav-col">
							<h4>Stay</h4>
							<a href={roomsHref}>Rooms</a>
							<a href="/book" class="footer-reservations-btn">Reservations</a>
						</div>
					</nav>
				</div>
				<div class="footer-bottom">
					<p>&copy; {new Date().getFullYear()} Saco Bay Hotel. A good place to stay in Saco.</p>
				</div>
			</div>
		</footer>


		<style is:global>
			html {
				scroll-behavior: smooth;
			}
			#main-header {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				padding: 2rem 4rem;
				z-index: 1000;
				transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
			}

			#main-header.scrolled {
				background: transparent;
				padding: 1.5rem 4rem;
			}

			.header-container {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				align-items: center;
				width: 100%;
				max-width: 1600px;
				margin: 0 auto;
				position: relative;
			}

			.nav-brand-link {
				display: inline-flex;
				align-items: center;
				position: absolute;
				left: 0;
				top: 50%;
				transform: translateY(-50%);
				opacity: 0;
				visibility: hidden;
				pointer-events: none;
				transition: opacity 0.6s cubic-bezier(0.165, 0.84, 0.44, 1), visibility 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
			}

			#main-header.scrolled .nav-brand-link {
				opacity: 1;
				visibility: visible;
				pointer-events: auto;
			}

			#main-header.hide-home-badge .nav-brand-link {
				opacity: 0;
				visibility: hidden;
				pointer-events: none;
			}

			.nav-brand-text {
				font-family: 'Cormorant Garamond', serif;
				font-size: 1.4rem;
				font-weight: 500;
				letter-spacing: 0.14rem;
				text-transform: uppercase;
				line-height: 1;
				white-space: nowrap;
				color: var(--navy-muted);
			}

				/* Logo Styles */
				.logo-text {
					font-family: 'Cormorant Garamond', serif;
					font-size: 2rem;
					font-weight: 500;
					letter-spacing: 0.18rem;
					text-transform: uppercase;
					line-height: 1;
					color: var(--white);
					transition: all 0.6s ease;
					white-space: nowrap;
				}

				.footer-logo {
					font-size: 1.6rem;
					letter-spacing: 0.14rem;
				}

			#main-header.scrolled .logo-full {
				opacity: 0;
				visibility: hidden;
				transform: translateY(-10px);
			}

			.header-actions {
				display: flex;
				align-items: center;
				gap: 2rem;
			}

			/* Hamburger Trigger */
			.menu-trigger {
				display: none; /* Hidden by default */
				background: transparent;
				border: none;
				cursor: pointer;
				flex-direction: column;
				gap: 5px;
				width: 25px;
				padding: 0;
				z-index: 1100;
				order: -1; /* Ensure it stays left of the Book Now button */
			}

			#main-header.scrolled .menu-trigger {
				display: flex;
			}

			.hamburger-line {
				display: block;
				width: 100%;
				height: 2px;
				background-color: var(--white);
				transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
			}

			#main-header.scrolled .hamburger-line {
				background-color: var(--accent);
			}

			body.menu-open .hamburger-line:nth-child(1) {
				transform: translateY(8px) rotate(45deg);
				background-color: var(--navy-deep) !important;
			}

			body.menu-open .hamburger-line:nth-child(2) {
				opacity: 0;
				transform: scaleX(0);
			}

			body.menu-open .hamburger-line:nth-child(3) {
				transform: translateY(-8px) rotate(-45deg);
				background-color: var(--navy-deep) !important;
			}

			/* Menu Dropdown */
			.menu-dropdown {
				position: fixed;
				top: 100px;
				right: 4rem;
				width: 320px;
				background: var(--white);
				z-index: 1050;
				box-shadow: 0 30px 60px rgba(0,0,0,0.15);
				border: 1px solid var(--border-blue);
				padding: 3rem;
				opacity: 0;
				visibility: hidden;
				transform: translateY(-20px);
				transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
			}

			body.menu-open .menu-dropdown {
				opacity: 1;
				visibility: visible;
				transform: translateY(0);
			}

			.menu-links {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				margin-bottom: 3rem;
			}

			.menu-link {
				font-family: 'Cinzel', serif;
				font-size: 1.4rem;
				text-transform: uppercase;
				letter-spacing: 0.2rem;
				color: var(--navy-deep);
				transition: all 0.3s ease;
			}

			.menu-link:hover {
				color: var(--accent);
				padding-left: 10px;
			}

			.menu-link-book {
				color: var(--accent);
		font-weight: 700;
			}

			.menu-dropdown-footer {
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.1rem;
				color: var(--text-muted);
				border-top: 1px solid var(--border-blue);
				padding-top: 2rem;
			}

			/* Navigation Visibility */
			.main-nav {
				display: flex;
				align-items: center;
				gap: 3rem;
				transition: all 0.4s ease;
			}

				.left-nav { justify-content: flex-start; }
				.right-nav { justify-content: flex-end; }

			#main-header.scrolled .left-nav,
			#main-header.scrolled .right-nav a:not(.btn-book) {
				opacity: 0;
				visibility: hidden;
				pointer-events: none;
			}

			.main-nav a {
				text-transform: uppercase;
				font-size: 0.8rem;
				letter-spacing: 0.2rem;
				font-weight: 500;
				color: var(--white);
				transition: all 0.3s ease;
				white-space: nowrap;
			}

			#main-header.scrolled .main-nav a:hover {
				color: var(--accent);
			}

			.btn-book {
				padding: 0.8rem 2rem;
				border: 1px solid var(--white);
				background: transparent;
				color: var(--white) !important;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.15rem;
				font-size: 0.8rem;
				transition: all 0.4s ease;
				cursor: pointer;
				font-family: inherit;
			}

			#main-header.scrolled .btn-book {
				background: var(--navy-muted);
				border-color: var(--navy-muted);
				box-shadow: 0 10px 25px rgba(38, 52, 82, 0.35);
			}

			.btn-book:hover {
				background: var(--white) !important;
				color: var(--navy-muted) !important;
				border-color: var(--white);
			}

			#main-header.scrolled .btn-book:hover {
				background: var(--navy-deep) !important;
				border-color: var(--navy-deep);
				transform: translateY(-2px);
			}

			/* Footer */
			footer {
				background-color: var(--bg-warm);
				padding: 0 0 5rem;
				color: var(--text-main);
				border-top: 1px solid var(--border-light);
			}

			.footer-content {
				padding-top: 5.5rem;
			}

			.footer-top {
				display: flex;
				justify-content: space-between;
			}

			.footer-brand .logo-text {
				color: var(--text-main);
				display: block;
				margin-bottom: 2rem;
			}

			.footer-brand p {
				color: var(--navy-muted);
				font-size: 0.9rem;
				margin-bottom: 0.5rem;
			}

			.footer-nav {
				display: flex;
				gap: 5rem;
			}

			.footer-nav-col h4 {
				text-transform: uppercase;
				font-size: 0.7rem;
				letter-spacing: 0.2rem;
				margin-bottom: 2.5rem;
				color: var(--navy-muted);
			}

			.footer-nav-col a {
				display: block;
				margin-bottom: 1.2rem;
				font-size: 0.85rem;
				color: var(--text-main);
				font-weight: 500;
			}

			.footer-nav-col a:hover {
				color: var(--accent);
			}

			.footer-reservations-btn {
				display: block;
				margin-bottom: 1.2rem;
				font-size: 0.85rem;
				color: var(--text-main);
				font-weight: 500;
				background: none;
				border: none;
				padding: 0;
				cursor: pointer;
				font-family: inherit;
				text-align: left;
			}

			.footer-reservations-btn:hover {
				color: var(--accent);
			}

			.footer-bottom {
				border-top: 1px solid var(--border-light);
				margin-top: 3rem;
				padding-top: 2rem;
				font-size: 0.75rem;
				color: var(--navy-muted);
				text-transform: uppercase;
				letter-spacing: 0.1rem;
				text-align: center;
			}

			@media (max-width: 1024px) {
				#main-header { padding: 2rem; }
				#main-header.scrolled { padding: 1rem 2rem; }
				.main-nav { gap: 1.5rem; }
				.footer-top { flex-direction: column; gap: 4rem; }
				.footer-nav { gap: 4rem; flex-wrap: wrap; }
			}

				@media (max-width: 768px) {
				#main-header {
					padding: 1.5rem 1.5rem;
				}

				.header-container {
					display: flex;
					justify-content: center;
					align-items: center;
					min-height: 2.5rem;
				}

				.header-left {
					position: absolute;
					left: 0;
					top: 50%;
					transform: translateY(-50%);
					display: none;
				}

					#main-header.scrolled .header-left {
						display: flex;
						align-items: center;
						left: 0;
						top: 50%;
						transform: translateY(-50%);
					}

					.header-left .left-nav {
						display: none;
					}

					.nav-brand-link {
						margin-right: 0;
					}

					.nav-brand-text {
						font-size: 1rem;
						letter-spacing: 0.08rem;
					}

				.header-center {
					display: flex;
					justify-content: center;
				}

					.header-right {
						position: absolute;
						right: 0;
						top: 50%;
						transform: translateY(-50%);
						display: flex;
				}

				#main-header.scrolled .header-right {
					display: flex;
				}

				.header-right .main-nav a:not(.btn-book) {
					display: none;
				}

				.menu-trigger {
					display: flex;
				}

				#main-header:not(.scrolled) .btn-book {
					display: none;
				}

					.logo-text {
						font-size: 2.2rem;
						letter-spacing: 0.14rem;
					}

				#main-header.scrolled .logo-full {
					display: none;
				}

				.header-actions {
					gap: 1rem;
				}

					.btn-book {
						padding: 0.7rem 1.4rem;
						font-size: 0.6rem;
					}

				.menu-dropdown {
					top: 70px;
					right: 1.5rem;
					width: calc(100% - 3rem);
					padding: 2rem;
				}
			}
		</style>

		<script>
				const header = document.getElementById('main-header');
				const menuToggle = document.getElementById('menu-toggle');
				const menuLinks = document.querySelectorAll('.menu-link');
				const isHome = header && !header.classList.contains('scrolled');

				const syncHeaderState = () => {
					const shouldScroll = window.scrollY > 50;

					if (isHome) {
						header?.classList.toggle('scrolled', shouldScroll);
					}

					header?.classList.toggle('hide-home-badge', shouldScroll);
				};

				// Scroll Logic
				if (isHome) {
					window.addEventListener('scroll', syncHeaderState);
				} else {
					header?.classList.add('scrolled');
					window.addEventListener('scroll', syncHeaderState);
				}

				syncHeaderState();

			// Menu Toggle Logic
			menuToggle?.addEventListener('click', (e) => {
				e.stopPropagation();
				document.body.classList.toggle('menu-open');
			});

			// Close menu when link is clicked
			menuLinks.forEach(link => {
				link.addEventListener('click', () => {
					document.body.classList.remove('menu-open');
				});
			});

			// Close menu when clicking outside
			document.addEventListener('click', (e) => {
				if (!document.body.classList.contains('menu-open')) return;
				const menu = document.getElementById('full-menu');
				if (menu && !menu.contains(e.target as Node)) {
					document.body.classList.remove('menu-open');
				}
			});
		</script>
	</body>
</html>
